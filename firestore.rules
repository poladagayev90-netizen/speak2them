rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.uid == '6Djehd9KB8dTZUgVwVJfLoPI5dF3';
    }

    function isOwnDoc(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isNotChangingPremiumFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['isPremium', 'premiumSince']);
    }

    function isNotCreatingPremiumFields() {
      return !request.resource.data.keys().hasAny(['isPremium', 'premiumSince']);
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwnDoc(userId) && isNotCreatingPremiumFields();
      allow update: if isAdmin() || (isOwnDoc(userId) && isNotChangingPremiumFields());
      allow delete: if isAdmin();
    }

    match /premiumRequests/{userId} {
      allow read: if isAdmin() || isOwnDoc(userId);
      allow create: if isOwnDoc(userId)
        && request.resource.data.uid == userId
        && request.resource.data.status == 'pending';
      allow update: if isAdmin() || (
        isOwnDoc(userId)
        && resource.data.status == 'pending'
        && request.resource.data.uid == userId
        && request.resource.data.status == 'pending'
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['activatedAt', 'activatedBy'])
      );
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, write: if request.auth.uid != null && (
        chatId == request.auth.uid + "_" ||
        chatId.split("_")[0] == request.auth.uid ||
        chatId.split("_")[1] == request.auth.uid
      );

      match /messages/{messageId} {
        allow read: if request.auth.uid != null && (
          chatId == request.auth.uid + "_" ||
          chatId.split("_")[0] == request.auth.uid ||
          chatId.split("_")[1] == request.auth.uid
        );
        allow create: if request.auth.uid == request.resource.data.senderId;
        allow update, delete: if request.auth.uid == resource.data.senderId;
      }
    }

    match /calls/{callId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.callerId;
      allow update: if request.auth.uid == resource.data.callerId || request.auth.uid == resource.data.receiverId;
      allow delete: if request.auth.uid == resource.data.callerId || request.auth.uid == resource.data.receiverId;
    }

    match /matchQueue/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
