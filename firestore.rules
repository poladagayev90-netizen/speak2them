rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.uid == '6Djehd9KB8dTZUgVwVJfLoPI5dF3';
    }

    function isOwnDoc(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 'isPro' was written by the client and read by nothing. It stays on the
    // list so it can never become a self-service premium flag if some view
    // starts honouring it later.
    // 'subscriptionPlan' and 'availableTrialMinutes' gate paid access, so like
    // the premium flags they must only ever be written by an admin or a Cloud
    // Function (admin SDK) — never self-served from the client.
    // The cohort/cycle fields below decide trial-vs-course access and course
    // progress. They are set once by the redeemCode / claimCourseCompletion
    // Cloud Functions (admin SDK); a client must never mutate them — otherwise a
    // modified client could self-promote to 'course', reset trialStartedAt to
    // dodge the 2-day gate, or forge course completion. trialStartedAt is
    // created (not updated) at registration, so it is on the update-guard list
    // but NOT the create-guard list.
    // cohortStatus burada MÜTLƏQDİR: client onu öz sənədinə yaza bilsəydi,
    // 'pending' trial gate-i keçər, 'accepted' isə adminin "Başlat"ında
    // təsdiqsiz kurs+premium verərdi. Yalnız server (redeemCode/startCohort,
    // Admin SDK) və admin paneli yaza bilər.
    // Müəllim sahələri: teacherId/completedSessions və s. yalnız server
    // (consumeTrialMinutes / claimTeacherCode / createInviteCode, Admin SDK)
    // tərəfindən yazılır. `role` və `teacherEligible` isə B2B2C onboarding-də
    // qeydiyyatda AÇIQ seçilir — ona görə client onları yalnız BİR DƏFƏ
    // (sahə hələ yoxdursa) və yalnız icazəli dəyərlərlə qoya bilər; sonradan
    // dəyişmək yenə qadağandır (rol dəyişmək = server/admin işi).
    function validRoleOneTimeSet() {
      return (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
          || (!('role' in resource.data) && request.resource.data.role in ['student', 'teacher']))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['teacherEligible'])
          || (!('teacherEligible' in resource.data)
            && request.resource.data.teacherEligible == true
            && request.resource.data.role == 'teacher'));
    }

    function isNotChangingPremiumFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['isPremium', 'premiumSince', 'premiumPlan', 'isPro', 'subscriptionPlan', 'availableTrialMinutes',
          'mode', 'startTick', 'cohortId', 'cohortStatus', 'cohortAppliedAt',
          'trialStartedAt', 'courseActivatedAt', 'courseCompletedAt', 'freeAccessUntil',
          'teacherId', 'teacherLinkedAt', 'teacherConsentAt', 'ageConfirmedAt',
          'isAdult', 'completedSessions'])
        && validRoleOneTimeSet();
    }

    function isNotCreatingPremiumFields() {
      return !request.resource.data.keys().hasAny(['isPremium', 'premiumSince', 'premiumPlan', 'isPro', 'subscriptionPlan', 'availableTrialMinutes',
          'startTick', 'cohortId', 'cohortStatus', 'cohortAppliedAt', 'courseActivatedAt', 'courseCompletedAt', 'freeAccessUntil',
          'teacherId', 'teacherLinkedAt', 'teacherConsentAt', 'ageConfirmedAt',
          'isAdult', 'completedSessions'])
        // A newly created doc may only self-declare the trial mode, never course.
        && (!request.resource.data.keys().hasAny(['mode']) || request.resource.data.mode == 'trial')
        // Rol yaradılışda seçilə bilər; teacherEligible yalnız teacher rolu ilə birgə.
        && (!request.resource.data.keys().hasAny(['role']) || request.resource.data.role in ['student', 'teacher'])
        && (!request.resource.data.keys().hasAny(['teacherEligible'])
          || (request.resource.data.teacherEligible == true && request.resource.data.role == 'teacher'));
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwnDoc(userId) && isNotCreatingPremiumFields();
      allow update: if isAdmin() || (isOwnDoc(userId) && isNotChangingPremiumFields());
      allow delete: if isAdmin();

      // Per-device FCM push tokens. Each device writes its own doc (id = hash of
      // the token) so devices don't overwrite each other. Only the owner
      // manages them; Cloud Functions read/prune via the Admin SDK.
      match /fcmTokens/{tokenId} {
        allow read, write: if isOwnDoc(userId);
      }

      // Blok siyahısı (Play UGC tələbi): sənədin mövcudluğu = blok. Yalnız
      // sahibi görür/idarə edir; sendCallNotification Admin SDK ilə oxuyur.
      match /blocked/{peerId} {
        allow read, write: if isOwnDoc(userId);
      }

      // Şəxsi məlumat (hazırda: yaş təsdiqi + valideyn razılığı). users/{uid}
      // sənədini hər daxil olmuş istifadəçi oxuya bilir (yuxarıdakı read
      // qaydası), ona görə xam doğum tarixi orada YOX, burada saxlanılır.
      // Yalnız claimTeacherCode (Admin SDK) yazır.
      match /private/{docId} {
        allow read: if isOwnDoc(userId);
        allow write: if false;
      }
    }

    // İstifadəçi şikayətləri (Play UGC tələbi). Client yalnız ÖZ adından
    // yarada bilir; oxumaq/dəyişmək yalnız adminə açıqdır — şikayət olunan
    // şəxs şikayəti görə bilməz.
    match /reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.keys().hasOnly(['reporterId', 'reportedId', 'reportedName', 'reason', 'createdAt', 'status'])
        && request.resource.data.status == 'open'
        && request.resource.data.reportedId is string
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 500;
      allow read, update, delete: if isAdmin();
    }

    match /premiumRequests/{userId} {
      allow read: if isAdmin() || isOwnDoc(userId);
      allow create: if isAdmin() || (
        isOwnDoc(userId)
        && request.resource.data.uid == userId
        && request.resource.data.status == 'pending'
      );
      allow update: if isAdmin() || (
        isOwnDoc(userId)
        && resource.data.status == 'pending'
        && request.resource.data.uid == userId
        && request.resource.data.status == 'pending'
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['activatedAt', 'activatedBy'])
      );
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, write: if request.auth.uid != null && (
        chatId == request.auth.uid + "_" ||
        chatId.split("_")[0] == request.auth.uid ||
        chatId.split("_")[1] == request.auth.uid
      );

      match /messages/{messageId} {
        allow read: if request.auth.uid != null && (
          chatId == request.auth.uid + "_" ||
          chatId.split("_")[0] == request.auth.uid ||
          chatId.split("_")[1] == request.auth.uid
        );
        allow create: if request.auth.uid == request.resource.data.senderId;
        allow update, delete: if request.auth.uid == resource.data.senderId;
      }
    }

    match /calls/{callId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.callerId || 
        request.auth.uid == resource.data.receiverId ||
        request.auth.uid == resource.data.userA || 
        request.auth.uid == resource.data.userB
      );
      allow create: if request.auth.uid == request.resource.data.callerId || 
                       request.auth.uid == request.resource.data.userA || 
                       request.auth.uid == request.resource.data.userB;
      allow update: if request.auth.uid == resource.data.callerId || 
                       request.auth.uid == resource.data.receiverId ||
                       request.auth.uid == resource.data.userA || 
                       request.auth.uid == resource.data.userB;
      allow delete: if request.auth.uid == resource.data.callerId || 
                       request.auth.uid == resource.data.receiverId ||
                       request.auth.uid == resource.data.userA || 
                       request.auth.uid == resource.data.userB;
    }

    match /matchQueue/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwnDoc(userId);
      // A peer may only flip a *searching* ticket to matched-with-themselves,
      // and only those four fields. Previously any signed-in user could
      // rewrite anyone's whole ticket (callId included) at any time.
      allow update: if isOwnDoc(userId) || (
        isSignedIn()
        && resource.data.status == 'searching'
        && request.resource.data.status == 'matched'
        && request.resource.data.matchedWith == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'matchedWith', 'callId', 'matchedAt'])
      );
      allow delete: if isOwnDoc(userId);
    }

    match /appConfig/{docId} {
      // Session schedule + cycle state — clients read it, only the admin edits
      // it. The cycle doc is advanced by the advanceCycle Cloud Function.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Cohorts hold the entry CODES, so normal clients must not read them (codes
    // would be enumerable). Redemption goes through the redeemCode Cloud
    // Function (admin SDK, bypasses rules); the admin panel reads them directly.
    // Exception: a MEMBER may read their own cohort doc (name/memberCount for
    // the welcome screen and the Home cohort card) — they already know its
    // code, and other cohorts' codes stay unreadable. `get` (not list), so the
    // collection can never be enumerated.
    match /cohorts/{cohortId} {
      allow get: if isAdmin() || (
        isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.cohortId == cohortId
      );
      allow list, write: if isAdmin();
    }

    match /waitlist/{docId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 5
        && request.resource.data.email.size() < 200;
      allow read, update, delete: if isAdmin();
    }

    match /analysisQueue/{docId} {
      // Clients may only create their own pending ticket pointing at their
      // own recording; claiming/retrying/deleting is done by the scheduled
      // worker through the Admin SDK (bypasses rules).
      allow create: if isSignedIn()
        && docId.split('_')[0] == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'status', 'storagePath', 'audioSeconds', 'uid', 'callDocId',
          'sessionId', 'peerName', 'retryCount', 'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.retryCount == 0
        && request.resource.data.audioSeconds is number
        && request.resource.data.audioSeconds > 0
        && request.resource.data.audioSeconds <= 1800
        && request.resource.data.callDocId is string
        && request.resource.data.sessionId is string
        && request.resource.data.storagePath ==
          'callRecordings/' + request.auth.uid + '/'
          + request.resource.data.callDocId + '_'
          + request.resource.data.sessionId + '.webm';
      allow read: if isSignedIn() && docId.split('_')[0] == request.auth.uid;
      allow update, delete: if false;
    }

    match /callAnalysis/{docId} {
      allow read: if isSignedIn() && (
        docId.split('_')[0] == request.auth.uid ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
      // Clients only seed the "queued" placeholder for their OWN recording.
      // The analysis itself is written by the worker through the Admin SDK.
      // The old rule OR'd the two clauses, so anyone could overwrite another
      // user's analysis simply by setting userId to their own uid.
      allow create: if isSignedIn()
        && docId.split('_')[0] == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'queued'
        && request.resource.data.keys().hasOnly(['status', 'userId', 'timestamp']);
      allow update, delete: if false;
    }

    match /wordHistory/{userId}/words/{wordId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Müəllim profili + şagird siyahısı. Yalnız müəllimin özü oxuyur; bütün
    // yazılar createInviteCode / claimTeacherCode (Admin SDK) üzərindəndir —
    // əks halda müəllim studentCap-ı və ya studentCount-u özü dəyişə bilərdi.
    match /teachers/{teacherId} {
      allow read: if isOwnDoc(teacherId);
      allow write: if false;

      match /roster/{studentId} {
        allow read: if isOwnDoc(teacherId);
        allow write: if false;
      }
    }

    // DİQQƏT: inviteCodes üçün QƏSDƏN match bloku yoxdur. Aşağıdakı catch-all
    // onu tam bağlayır və bu, tam olaraq istənilən davranışdır: kodu yoxlamaq
    // yalnız serverdə (claimTeacherCode) baş verir, oxumağı bağlamaq isə
    // kolleksiyanı sayıb işlək kod tapmağın (enumeration) qarşısını alır.
    // Buraya "rahatlıq üçün" read əlavə etmək bütün kodları ifşa edər.

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
