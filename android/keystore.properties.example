# Release signing config for the Play Store upload key.
# Copy this file to `keystore.properties` (same folder) and fill in real values.
# The real keystore.properties and *.jks/*.keystore files are git-ignored —
# NEVER commit them, and keep a secure backup of the .jks + these passwords.
# Losing the upload key means you can no longer update the app on Play.

storeFile=upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
